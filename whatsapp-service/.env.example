PORT=4100
# Debe coincidir EXACTAMENTE con WHATSAPP_SERVICE_INTERNAL_SECRET del backend Python
WHATSAPP_SERVICE_INTERNAL_SECRET=cambia_esto_por_un_secreto_largo
BACKEND_URL=http://localhost:4000
WHATSAPP_AUTH_DIR=./auth_info
LOG_LEVEL=info
# Milisegundos antes de abortar el POST al backend si no responde.
# Ver README.md — lección aprendida del leak en whatsapp-bot de terapias.
BACKEND_TIMEOUT_MS=30000
# Milisegundos que se le da a connectToWhatsApp() para llegar a QR_PENDING
# o CONNECTED antes de asumir que Chromium quedó colgado por dentro y
# forzar una reconexión sola. Ver incidente real del 16-jul-2026 (sesión
# corrupta en WHATSAPP_AUTH_DIR dejaba el proceso en CONNECTING para
# siempre, sin ningún error). Default 90s, bien por encima de lo que tarda
# un connect sano.
WHATSAPP_CONNECT_TIMEOUT_MS=90000
