# MedicBolivia Frontend — Variables de entorno
# Copiar como .env.local

# URL del backend FastAPI. Usar la ruta RELATIVA "/api/v1" (no
# "http://localhost:4000/api/v1") para que las requests salgan desde el
# navegador hacia localhost:3000 (mismo origen que el frontend) y Next
# las reenvíe a localhost:4000 por atrás — ver rewrites() en
# next.config.js. Esto es necesario para que la cookie httpOnly de auth
# (SameSite=Strict) viaje correctamente en desarrollo local; con una URL
# absoluta a otro puerto, el navegador la bloquearía por ser cross-origin.
NEXT_PUBLIC_API_URL=/api/v1

# Si tu backend local corre en otro host/puerto que no sea
# localhost:4000, cambialo acá (lo usa el rewrite de next.config.js,
# NO el navegador directamente):
BACKEND_URL_FOR_DEV_PROXY=http://localhost:4000

# No usado actualmente por el código (el WebSocket del chat se arma a
# partir de NEXT_PUBLIC_API_URL) — se deja documentado por si hiciera
# falta en el futuro.
NEXT_PUBLIC_WS_URL=ws://localhost:4000
