# MedicBolivia Backend — Variables de entorno
# Copiar este archivo como .env y llenar los valores reales
# NUNCA subir el .env real a Git

# ── App ──────────────────────────────────────────────
APP_NAME=MedicBolivia
ENVIRONMENT=development
DEBUG=true

# ── Base de datos PostgreSQL ─────────────────────────
# Formato: postgresql+asyncpg://usuario:contraseña@host:puerto/basededatos
DATABASE_URL=postgresql+asyncpg://medicbolivia:tu_password_aqui@localhost:5432/medicbolivia
DATABASE_URL_SYNC=postgresql://medicbolivia:tu_password_aqui@localhost:5432/medicbolivia

# ── Redis ────────────────────────────────────────────
# En desarrollo local (Memurai/Redis sin password): redis://localhost:6379
# En el VPS de producción: usá la línea que te imprime deploy_vps.sh, con
# password incluida, ej: redis://:TU_PASSWORD@localhost:6379
REDIS_URL=redis://localhost:6379
# Redis dedicado a seguridad (OTP de WhatsApp, bloqueo de login). En
# desarrollo podés dejarlo vacío (cae al mismo REDIS_URL de arriba). En
# producción, correr scripts/setup_redis_security.sh y usar esa URL
# (puerto 6380, con su propia password).
AUTH_REDIS_URL=

# ── Seguridad JWT ────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CAMBIA_ESTO_POR_UN_SECRETO_MUY_LARGO_Y_ALEATORIO
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Anthropic — Claude ───────────────────────────────
# Obtener en: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ── ElevenLabs — Voz del agente ──────────────────────
# Obtener en: https://elevenlabs.io
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...

# ── Google Places — Buscador de médicos (panel admin) ─
# Habilitar "Places API (New)" y crear la clave en:
# https://console.cloud.google.com/apis/credentials
# Restringir la clave solo a "Places API (New)". Opcional: si se deja
# vacío, el buscador de /admin/doctor-leads devuelve 503 (el resto de
# la plataforma funciona igual sin esto).
GOOGLE_PLACES_API_KEY=

# ── Twilio — Llamadas y SMS ──────────────────────────
# Obtener en: https://console.twilio.com
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# ── AWS S3 — Documentos médicos ──────────────────────
# Crear bucket privado en región sa-east-1 (São Paulo)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_BUCKET_NAME=medicbolivia-docs
AWS_REGION=sa-east-1

# ── Pagos QR ─────────────────────────────────────────
QR_EXPIRY_MINUTES=5
PLATFORM_FEE_PERCENT=0.15
PAYMENT_RELEASE_MINUTES=15

# ── CORS — Frontend Next.js ──────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","https://medicbolivia.bo"]

# ── Celery (recordatorios + backups programados) ──
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── whatsapp-service (microservicio Node/Baileys) ──
WHATSAPP_SERVICE_URL=http://localhost:4100
WHATSAPP_SERVICE_INTERNAL_SECRET=cambia_esto_por_un_secreto_largo

# ── Gmail (backups automaticos de la BD) ──
# Generar en https://myaccount.google.com/apppasswords (requiere 2FA activo)
GMAIL_SENDER_ADDRESS=
GMAIL_APP_PASSWORD=
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587
BACKUP_MAX_ATTACHMENT_MB=20

# ── SMTP Hostinger (formulario de contacto de la landing) ──
# Credenciales del buzón info@medicbolivia.com en Hostinger (Panel hPanel →
# Correo → esa cuenta → "Configurar cliente de correo" te da estos datos).
CONTACT_SMTP_HOST=smtp.hostinger.com
CONTACT_SMTP_PORT=465
CONTACT_SMTP_USER=info@medicbolivia.com
CONTACT_SMTP_PASSWORD=
CONTACT_RECIPIENT_EMAIL=info@medicbolivia.com
CONTACT_FORM_MAX_PER_HOUR=5
